{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@shared/*": ["./shared/*"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["tests/**/*.ts", "electron/**/*.ts", "shared/**/*.ts"]
}